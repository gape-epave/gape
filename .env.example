# ─────────────────────────────────────────────────────────────
# GAPE — Variáveis de ambiente
# Copia para .env.local (nunca commitar o .env.local)
# No Vercel: Settings → Environment Variables → adicionar cada uma
# ─────────────────────────────────────────────────────────────

# EmailJS — obtidas em https://dashboard.emailjs.com
VITE_EMAILJS_SERVICE=service_xxxxxxx
VITE_EMAILJS_TEMPLATE=template_xxxxxxx
VITE_EMAILJS_KEY=xxxxxxxxxxxxxxxxxxxx
